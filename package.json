{
  "name": "zipit-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "ZipIt — Client-side ZIP streaming & batch download library",
  "scripts": {
    "dev": "pnpm --filter @zipit/web dev",
    "dev:docs": "pnpm --filter @zipit/docs dev",
    "build": "pnpm -r --filter '@zipit/core' --filter '@zipit/react' build",
    "build:all": "pnpm -r build",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test:coverage",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "release": "pnpm -r --filter '@zipit/core' --filter '@zipit/react' publish --access public"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "prettier": "^3.2.5",
    "@changesets/cli": "^2.27.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  }
}
