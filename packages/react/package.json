{
  "name": "@zipit/react",
  "version": "0.1.0",
  "description": "React hooks for @zipit/core — useZipIt, useZip",
  "license": "MIT",
  "author": "Rochak Sulu",
  "keywords": ["zipit", "react", "hooks", "download", "zip", "streaming"],
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "README.md"],
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc --noEmit && vite build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "@zipit/core": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@zipit/core": "workspace:*",
    "react": "^18.0.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.8.0",
    "vitest": "^1.5.0",
    "typescript": "^5.4.0",
    "@vitest/coverage-v8": "^1.5.0",
    "@testing-library/react": "^15.0.0",
    "@testing-library/user-event": "^14.0.0"
  }
}
